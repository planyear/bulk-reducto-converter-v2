OCR=docling
REDUCTO_API_KEY=
REDUCTO_API_URL=https://platform.reducto.ai
MAX_UPLOAD_BYTES=209715200
MAX_FILES_PER_JOB=50
PER_FILE_TIMEOUT_S=300

# WorkOS AuthKit — copy this file to .env and fill in real values.
# See README.md for where to get each value from the WorkOS dashboard.
WORKOS_API_KEY=sk_test_xxxxxxxxxxxxxxxx
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxx
WORKOS_REDIRECT_URI=http://localhost:8000/auth/callback
# Generate a 32+ char secret. POSIX:  openssl rand -base64 32
# PowerShell:  [Convert]::ToBase64String((1..32 | %{ Get-Random -Maximum 256 }))
WORKOS_COOKIE_PASSWORD=replace_with_32_plus_char_random_string
# Test Organization ID (verified domain example.com). Leave blank to disable
# the default org and use AuthKit's generic hosted page (email/password/social).
WORKOS_DEFAULT_ORG_ID=org_xxxxxxxxxxxxxxxx
APP_BASE_URL=http://localhost:8000
